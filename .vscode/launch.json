    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch LTV Assume",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/aws-cli-oidc",
            "args": ["get-cred", "--provider", "production"],
            "env": {},
            "showLog": true
        },
        {
            "name": "Launch Tests",
            "type": "go",
            "request": "launch",
            "mode": "test",
            "program": "${fileDirname}",
            "args": [
                "-test.v"
            ],
            "showLog": true
        },
        {
            "name": "Launch Current File",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${file}",
            "args": [],
            "showLog": true
        }
    ]
}